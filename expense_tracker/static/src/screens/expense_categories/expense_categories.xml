<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="expense_tracker.CategoriesList">
        <div class="rounded-6 shadow p-4 o_content_modal_rounded_shades height-container overflow-auto">
            <div class="mb-4 d-flex justify-content-between" t-if="!this.props.ignoreCreate">
                <h2 class="text-white mt-2">
                    Categories
                </h2>
                <div>
                    <button type="button" class="btn btn-primary mx-1 me-2" t-on-click="this._onClickAddCategory">
                        <span class="fs-3">Create New Category</span>
                    </button>
                    <button t-if="this.state.selectedCategories.length" type="button" class="btn btn-primary" t-on-click="this.deleteCategory">
                        <span class="fs-3">Delete Category</span>
                    </button>
                </div>
            </div>
            <hr />
            <div class="d-flex border-3 mx-auto">
                <table class="table table-dark table-hover mb-0">
                    <thead>
                        <tr class="table-success">
                            <th></th>
                            <th>Name</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="this.state.categories" t-as="category" t-key="category.id">
                            <tr t-att-data-id="category.id" t-on-click="this._onClickCategory" class="cursor-pointer">
                                <td>
                                    <input t-if="!this.props.ignoreCreate" type="checkbox" class="form-check-input cursor-pointer" t-att-data-id="category.id" t-on-click="this._onCategorySelection"/>
                                </td>
                                <td>
                                    <t t-out="category.name"/>
                                </td>
                                <td>
                                    <t t-out="category.description"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
