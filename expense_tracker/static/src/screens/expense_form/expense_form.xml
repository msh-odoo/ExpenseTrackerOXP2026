<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="expense_tracker.ExpenseForm">
        <div class="expense-form">
            <FormViewStatic data="this.state.data">
                <t t-set-slot="title">
                    <div class="">
                        <h1 class="text-white"><t t-out="this.title"/></h1>
                    </div>
                    <hr />
                </t>
                <t t-set-slot="content">
                    <div t-attf-class="{{!this.state.isValidForm and 'o_invalid' or ''}} m-auto mt-4" t-ref="this.form" style="width:70%">
                        <div t-if="!this.state.isValidForm" class="alert alert-danger">
                            Please enter right data!
                        </div>
                        <div class="mb-3 row d-flex align-items-center">
                            <label class="fs-2 col-sm-3 col-form-label">Description :</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control text-white o_expense_description" t-att-value="this.state.data.record and this.state.data.record.name" required="true"/>
                            </div>
                        </div>
                        <div class="mb-3 row d-flex align-items-center">
                            <label class="fs-2 col-sm-3 col-form-label">Date :</label>
                            <div class="col-sm-9">
                                <input type="date" class="form-control text-white o_expense_date" t-att-value="this.state.data.record and this.state.data.record.date" required="true"/>
                            </div>
                        </div>
                        <div class="mb-3 row d-flex align-items-center">
                            <label class="fs-2 col-sm-3 col-form-label">Amount :</label>
                            <div class="col-sm-9">
                                <input type="number" class="form-control text-white o_expense_amount" t-att-value="this.state.data.record and this.state.data.record.amount" required="true"/>
                            </div>
                        </div>
                        <div class="mb-4 row form-group d-flex align-items-center">
                            <label class="fs-2 col-sm-3 col-form-label">Category:</label>
                            <div class="col-sm-9">
                                <select class="form-select text-white o_expense_category">
                                    <t t-if="this.state.data and this.state.data.categories">
                                        <t t-foreach="this.state.data.categories" t-as="category" t-key="category.id">
                                            <option class="text-dark" t-att-value="category.id"><t t-out="category.name"/></option>
                                        </t>
                                    </t>
                                </select>
                            </div>
                        </div>
                        <t t-set-slot="footer">
                            <div class="w-100" t-ref="this.footer">
                                <button type="button" class="btn btn-primary" t-on-click="_onClickSubmitForm">
                                    <span class="fs-3">Save</span>
                                </button>
                            </div>
                        </t>
                    </div>
                </t>
            </FormViewStatic>
        </div>
    </t>
</templates>
