<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="expense_tracker.PersonalExpenseList">
        <div t-att-class="this.props.class" class="rounded-6 shadow p-4 o_content_modal_rounded_shades height-container expense_list">
            <div class="mb-4 d-flex justify-content-between" t-if="!this.props.ignoreCreate">
                <h2 class="text-white">
                    Personal Expenses
                </h2>
                <div>
                    <button type="button" class="btn btn-primary me-2" t-on-click="this._onCreateExpense">
                        <span class="fs-3">Create Expense</span>
                    </button>
                    <button t-if="this.state.selectedCheckboxes.length" type="button" class="btn btn-primary" t-on-click="this.deleteExpense">
                        <span class="fs-3">Delete Expense</span>
                    </button>
                </div>
            </div>
            <t t-if="!this.props.class">
                <hr/>
            </t>
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr class="table-success">
                        <th t-if="!this.props.ignoreCreate"></th>
                        <th>Description</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Category</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="this.state.expenses" t-as="expense" t-key="expense.id">
                        <tr t-att-data-id="expense.id" t-on-click="this._onClickExpenseRow" class="cursor-pointer">
                            <td t-if="!this.props.ignoreCreate">
                                <input type="checkbox" class="form-check-input" t-att-data-id="expense.id" t-on-click="this._onCheckboxChange"/>
                            </td>
                            <td><t t-out="expense.name"/></td>
                            <td><t t-out="expense.date"/></td>
                            <td><t t-out="expense.amount"/></td>
                            <td><t t-out="expense.category_id[1]"/></td>
                        </tr>
                    </t>
                </tbody>
                <tfoot>
                    <tr class="table-dark">
                        <td t-attf-colspan="{{!this.props.ignoreCreate and 3 or 2}}"></td>
                        <td>
                            <b>Total Amount: <t t-out="this.totalAmount"/></b>
                        </td>
                        <td></td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </t>
</templates>
